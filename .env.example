# =============================================================================
# Required environment variables
# The bot will log each missing variable and exit(1) if any are absent.
# =============================================================================

# Telegram bot token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# StarkZap API key — Privy/Cartridge app ID or server-side private key
STARKZAP_API_KEY=your_starkzap_api_key_here

# Extended Exchange REST API base URL
EXTENDED_API_BASE=https://api.starknet.sepolia.extended.exchange

# X-Api-Key header value for authenticated Extended Exchange endpoints
EXTENDED_API_KEY=your_extended_api_key_here

# L2 Starknet private key used to generate Stark signatures for order settlement
EXTENDED_STARK_PRIVATE_KEY=your_stark_private_key_here

# =============================================================================
# Optional environment variables
# =============================================================================

# Starknet network to connect to (default: sepolia)
# NETWORK=sepolia

# Privy application ID — required when using the Privy onboarding strategy
# PRIVY_APP_ID=your_privy_app_id_here

# Cartridge API key — required when using the Cartridge onboarding strategy
# CARTRIDGE_API_KEY=your_cartridge_api_key_here
